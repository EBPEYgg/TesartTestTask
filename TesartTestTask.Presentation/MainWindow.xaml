<Window x:Class="TesartTestTask.Presentation.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:behaviors="clr-namespace:TesartTestTask.Presentation.Behaviors"
        xmlns:converters="clr-namespace:TesartTestTask.Presentation.Converters"
        Title="Мониторинг измерительных устройств"
        Height="700"
        Width="1200"
        MinHeight="700"
        MinWidth="1200">
    <Window.Resources>
        <ResourceDictionary>
            <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
            <converters:EnumDescriptionConverter x:Key="EnumDescriptionConverter" />
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles/MainWindowStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <i:Interaction.Behaviors>
        <behaviors:AsyncClosingBehavior/>
    </i:Interaction.Behaviors>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="False" Margin="0 0 0 10">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                <Button Content="Старт" Command="{Binding StartCommand}" />
                <Button Content="Стоп" Command="{Binding StopCommand}" />
                <Button Content="Пауза" Command="{Binding PauseCommand}" />
                <Button Content="Продолжить" Command="{Binding ResumeCommand}" />
                <Button Content="Очистить историю" Command="{Binding ClearHistoryCommand}" />
                <Button Content="Экспорт" Command="{Binding ExportCommand}" />
            </StackPanel>

            <Border DockPanel.Dock="Right"
                    BorderBrush="#D8DEE8"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="10 6"
                    Background="#F8FAFC">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Опрос:" FontWeight="SemiBold" Margin="0 0 5 0" />
                    <TextBlock Text="{Binding PollingStateText}" />
                </StackPanel>
            </Border>
        </DockPanel>

        <Grid Grid.Row="1" Margin="0 0 0 10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Тип устройства" VerticalAlignment="Center" Margin="0 0 10 0" />
                <ComboBox Margin="0 0 10 0"
                          ItemsSource="{Binding DeviceTypeFilters}"
                          SelectedItem="{Binding SelectedDeviceTypeFilter}"
                          DisplayMemberPath="DisplayName" />
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Статус устройства" VerticalAlignment="Center" Margin="0 0 10 0" />
                <ComboBox Margin="0 0 10 0"
                          ItemsSource="{Binding StatusFilters}"
                          SelectedItem="{Binding SelectedStatusFilter}"
                          DisplayMemberPath="DisplayName" />
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Margin="0 0 10 0" Text="Поиск" VerticalAlignment="Center" />
                <TextBox MinWidth="200" Text="{Binding SearchText}" HorizontalAlignment="Stretch" />
                <Button Content="Найти" Command="{Binding FindCommand}" />
                <Button Content="❌" Command="{Binding ClearSearchTextCommand}" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.15*" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <GroupBox Grid.Column="0" Header="Устройства">
                <DataGrid ItemsSource="{Binding DeviceView}"
                          SelectedItem="{Binding SelectedDevice}"
                          Margin="5">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="1.4*" />
                        <DataGridTextColumn Header="Тип" Binding="{Binding DeviceType, Converter={StaticResource EnumDescriptionConverter}}" Width="1.5*" />
                        <DataGridTextColumn Header="Статус" Binding="{Binding Status, Converter={StaticResource EnumDescriptionConverter}}" Width="0.9*" />
                        <DataGridTextColumn Header="Значение" Binding="{Binding LastValue, StringFormat={}{0:F3}, TargetNullValue=-}" Width="0.9*" />
                        <DataGridTextColumn Header="Дата" Binding="{Binding LastUpdateTime, StringFormat={}{0:dd-MM-yyyy HH:mm:ss}, TargetNullValue=-}" Width="1.4*" />
                        <DataGridTextColumn Header="Интервал" Binding="{Binding PollingIntervalMs, StringFormat={}{0} ms}" Width="0.9*" />
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <GroupBox Grid.Row="0" Header="Выбранное устройство">
                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Имя" FontWeight="SemiBold" Margin="0 0 10 5" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedDevice.Name}" Margin="0 0 0 5" />
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Тип" FontWeight="SemiBold" Margin="0 0 10 5" />
                        <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding SelectedDevice.DeviceType, Converter={StaticResource EnumDescriptionConverter}}" Margin="0 0 0 5" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Статус" FontWeight="SemiBold" Margin="0 0 10 5" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedDevice.Status, Converter={StaticResource EnumDescriptionConverter}}" Margin="0 0 15 5" />
                        <TextBlock Grid.Row="1" Grid.Column="2" Text="Последнее значение" FontWeight="SemiBold" Margin="0 0 10 5" />
                        <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding SelectedDevice.LastValue, StringFormat={}{0:F3}, TargetNullValue=-}" Margin="0 0 0 5" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Дата" FontWeight="SemiBold" Margin="0 0 10 0" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedDevice.LastUpdateTime, StringFormat={}{0:dd-MM-yyyy HH:mm:ss}, TargetNullValue=-}" />
                        <TextBlock Grid.Row="2" Grid.Column="2" Text="Интервал опроса" FontWeight="SemiBold" Margin="0 0 10 0" />
                        <TextBlock Grid.Row="2" Grid.Column="3" Text="{Binding SelectedDevice.PollingIntervalMs, StringFormat={}{0} ms}" />
                    </Grid>
                </GroupBox>

                <GroupBox Grid.Row="2"
                          Header="История измерений">
                    <DataGrid ItemsSource="{Binding Measurements}"
                              Margin="5"
                              VerticalScrollBarVisibility="Visible">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Дата" Binding="{Binding Timestamp, StringFormat={}{0:dd-MM-yyyy HH:mm:ss}}" Width="1.4*" />
                            <DataGridTextColumn Header="Значение" Binding="{Binding Value, StringFormat={}{0:F3}, TargetNullValue=-}" Width="*" />
                            <DataGridCheckBoxColumn Header="Успешно" Binding="{Binding IsSuccess, Mode=OneWay}" Width="*" />
                            <DataGridTextColumn Header="Ошибка" Binding="{Binding ErrorMessage, TargetNullValue=-}" Width="1.8*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </GroupBox>
            </Grid>
        </Grid>

        <Border Grid.Row="3"
                BorderBrush="#D8DEE8"
                BorderThickness="1 0 0 0"
                Padding="5 5 0 5"
                Margin="0 15 0 0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left"
                           Text="{Binding StatusMessage}"
                           TextWrapping="Wrap" />
                <TextBlock DockPanel.Dock="Right"
                           Text="Загрузка..."
                           Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}" />
            </DockPanel>
        </Border>
    </Grid>
</Window>